# Copy to .env.local and fill in. NEVER commit .env.local. NEVER prefix these NEXT_PUBLIC_.
# These keys are used ONLY in server-side route handlers (app/api/*), never in the browser.

# Google AI Studio -> https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional: override the Gemini model (default: gemini-flash-latest).
# Note: pinned free-tier names like gemini-2.0-flash may return HTTP 429 with
# "limit: 0" on some projects/regions; gemini-flash-latest has free quota.
GEMINI_MODEL=gemini-flash-latest

# ElevenLabs -> https://elevenlabs.io  (Profile -> API key)
ELEVENLABS_API_KEY=

# Optional: voice ID (default: onwK4e9ZLuTAKqWW03F9 = "Daniel — Steady Broadcaster").
# Must be a PREMADE voice for free-tier API keys; library voices (e.g. "Rachel"
# 21m00Tcm4TlvDq8ikWAM) return HTTP 402 unless you're on a paid plan.
ELEVENLABS_VOICE_ID=onwK4e9ZLuTAKqWW03F9
